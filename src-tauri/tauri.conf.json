{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "HwanNote",
  "version": "0.8.1",
  "identifier": "com.hwankr.hwannote",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "npm run dev:frontend",
    "beforeBuildCommand": "npm run build:frontend"
  },
  "app": {
    "windows": [
      {
        "title": "HwanNote",
        "width": 1280,
        "height": 840,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "../resources/icon.png"
    ],
    "fileAssociations": [
      {
        "ext": [
          "md"
        ],
        "mimeType": "text/markdown",
        "description": "Markdown Document"
      },
      {
        "ext": [
          "txt"
        ],
        "mimeType": "text/plain",
        "description": "Text Document"
      }
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/hwankr/hwanNote/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "windows": {
        "installMode": "passive"
      },
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdFNDczMzUzMTdCOTk4NUQKUldSZG1Ma1hVek5IZnVCN2xSZEFFN1BVY1Vzc1ptN1JEeEI0RzZTTGthTFY2WjZEZHVHSE1udzAK"
    }
  }
}
